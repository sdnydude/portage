# Database
DATABASE_URL=postgresql://portage:portage@10.0.0.251:5436/portage

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=portage-images
R2_PUBLIC_URL=https://your-r2-public-url

# eBay
EBAY_CLIENT_ID=your-client-id
EBAY_CLIENT_SECRET=your-client-secret
EBAY_REDIRECT_URI=https://portage.digitalharmonyai.com/auth/ebay/callback
EBAY_SANDBOX=true

# Etsy
ETSY_API_KEY=your-api-key
ETSY_REDIRECT_URI=https://portage.digitalharmonyai.com/auth/etsy/callback

# EasyPost
EASYPOST_API_KEY=your-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_EMAIL=mailto:support@portageai.com

# App
NODE_ENV=development
API_PORT=8016
WEB_PORT=3002
